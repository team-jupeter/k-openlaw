# K-OpenLaw 시뮬레이션 환경변수 설정
# 이 파일을 복사하여 .env 파일을 생성한 후 각 값을 입력하십시오.
# cp .env.example .env

# DeepSeek API 키 (platform.deepseek.com → API Keys → Create)
DEEPSEEK_API_KEY=sk-여기에_입력

# Anthropic Claude API 키 (console.anthropic.com → Settings → API Keys → Create Key)
ANTHROPIC_API_KEY=sk-ant-여기에_입력

# 선택사항 — 추가 LLM 사용 시
OPENAI_API_KEY=여기에_입력
GEMINI_API_KEY=여기에_입력
GROK_API_KEY=여기에_입력
